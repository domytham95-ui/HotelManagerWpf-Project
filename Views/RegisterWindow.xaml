<Window x:Class="HotelManagerWpf.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Account"
        Height="680"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EAFBF1">

    <Window.Resources>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#15803D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="26">
        <Border Background="White"
                CornerRadius="24"
                Padding="36"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.16"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="Create Account"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#064E3B"/>

                <TextBlock Text="Register a new system user"
                           FontSize="14"
                           Foreground="#6B7280"
                           Margin="0,8,0,28"/>

                <TextBlock Text="Username"
                           FontWeight="SemiBold"
                           Foreground="#374151"/>

                <TextBox x:Name="UsernameTextBox"
                         Style="{StaticResource InputTextBox}"
                         Margin="0,8,0,16"/>

                <TextBlock Text="Password"
                           FontWeight="SemiBold"
                           Foreground="#374151"/>

                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource InputPasswordBox}"
                             Margin="0,8,0,16"/>

                <TextBlock Text="Confirm Password"
                           FontWeight="SemiBold"
                           Foreground="#374151"/>

                <PasswordBox x:Name="ConfirmPasswordBox"
                             Style="{StaticResource InputPasswordBox}"
                             Margin="0,8,0,16"/>

                <TextBlock Text="Role"
                           FontWeight="SemiBold"
                           Foreground="#374151"/>

                <ComboBox x:Name="RoleComboBox"
                          Height="42"
                          Margin="0,8,0,26"
                          SelectedIndex="2">
                    <ComboBoxItem Content="Admin"/>
                    <ComboBoxItem Content="Manager"/>
                    <ComboBoxItem Content="Staff"/>
                </ComboBox>

                <Button Content="Register"
                        Style="{StaticResource PrimaryButton}"
                        Click="RegisterButton_Click"/>

                <Button Content="Back to login"
                        Style="{StaticResource LinkButton}"
                        Margin="0,12,0,0"
                        Click="CloseButton_Click"/>
            </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>

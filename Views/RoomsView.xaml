<UserControl x:Class="HotelManagerWpf.Views.RoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Room Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="#065F46"
                   Margin="0,0,0,24"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="18"
                    Padding="22">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Room Form"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#065F46"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Room Number"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="RoomNumberTextBox"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Room Type"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="RoomTypeComboBox"
                              Margin="0,6,0,12">
                        <ComboBoxItem Content="Standard"/>
                        <ComboBoxItem Content="Deluxe"/>
                        <ComboBoxItem Content="VIP"/>
                    </ComboBox>

                    <TextBlock Text="Bed Type"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="BedTypeComboBox"
                              Margin="0,6,0,12">
                        <ComboBoxItem Content="Single"/>
                        <ComboBoxItem Content="Double"/>
                        <ComboBoxItem Content="Queen"/>
                        <ComboBoxItem Content="King"/>
                    </ComboBox>

                    <TextBlock Text="Price Per Night"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="PriceTextBox"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Status"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="StatusComboBox"
                              Margin="0,6,0,18">
                        <ComboBoxItem Content="Available"/>
                        <ComboBoxItem Content="Occupied"/>
                        <ComboBoxItem Content="Maintenance"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save"
                                Style="{StaticResource SuccessActionButton}"
                                Click="SaveButton_Click"/>

                        <Button Content="Clear"
                                Style="{StaticResource SecondaryActionButton}"
                                Click="ClearButton_Click"/>

                        <Button x:Name="DeleteButton"
                                Content="Delete"
                                Style="{StaticResource DangerActionButton}"
                                Click="DeleteButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="18"
                    Padding="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Border.Effect>

                <DataGrid x:Name="RoomsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="RoomsDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="70"/>

                        <DataGridTextColumn Header="Room No"
                                            Binding="{Binding RoomNumber}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding RoomType}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Bed"
                                            Binding="{Binding BedType}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding PricePerNight}"
                                            Width="140"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

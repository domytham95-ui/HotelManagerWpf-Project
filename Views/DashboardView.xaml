<UserControl x:Class="HotelManagerWpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="DashboardCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#DFF7E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14"
                                      ShadowDepth="0"
                                      Opacity="0.07"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#064E3B"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="PanelHeading" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#064E3B"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="22"
                    Padding="26"
                    Margin="0,0,0,22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#064E3B" Offset="0"/>
                        <GradientStop Color="#0F766E" Offset="0.55"/>
                        <GradientStop Color="#16A34A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.14"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Dashboard"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock x:Name="TodayTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="#DCFCE7"
                                   Text="Hotel performance overview"/>

                        <TextBlock Text="Track room availability, active bookings, and daily operations from one place."
                                   Margin="0,18,0,0"
                                   FontSize="15"
                                   Foreground="#F0FDF4"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="170"
                            Padding="18"
                            Background="#22C55E"
                            CornerRadius="16"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Revenue"
                                       Foreground="#DCFCE7"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="HeroRevenueTextBlock"
                                       Margin="0,8,0,0"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="26"
                                       FontWeight="Bold"/>
                            <TextBlock Text="active bookings"
                                       Margin="0,4,0,0"
                                       Foreground="#ECFDF5"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,0,0,22">
                <Border Style="{StaticResource DashboardCard}" Margin="0,0,14,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Total Rooms" Style="{StaticResource MetricLabel}"/>
                            <TextBlock x:Name="RoomsCountTextBlock" Margin="0,10,0,0" Style="{StaticResource MetricValue}" Text="0"/>
                            <TextBlock Text="configured rooms" Foreground="#94A3B8" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="42" Height="42" Background="#DCFCE7" CornerRadius="12">
                            <TextBlock Text="R" Foreground="#15803D" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DashboardCard}" Margin="0,0,14,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Available" Style="{StaticResource MetricLabel}"/>
                            <TextBlock x:Name="AvailableRoomsCountTextBlock" Margin="0,10,0,0" Style="{StaticResource MetricValue}" Text="0"/>
                            <TextBlock Text="ready for guests" Foreground="#94A3B8" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="42" Height="42" Background="#E0F2FE" CornerRadius="12">
                            <TextBlock Text="A" Foreground="#0369A1" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DashboardCard}" Margin="0,0,14,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Active Bookings" Style="{StaticResource MetricLabel}"/>
                            <TextBlock x:Name="ActiveBookingsCountTextBlock" Margin="0,10,0,0" Style="{StaticResource MetricValue}" Text="0"/>
                            <TextBlock Text="currently staying" Foreground="#94A3B8" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="42" Height="42" Background="#FEF3C7" CornerRadius="12">
                            <TextBlock Text="B" Foreground="#B45309" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DashboardCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Employees" Style="{StaticResource MetricLabel}"/>
                            <TextBlock x:Name="EmployeesCountTextBlock" Margin="0,10,0,0" Style="{StaticResource MetricValue}" Text="0"/>
                            <TextBlock Text="team members" Foreground="#94A3B8" FontSize="12"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="42" Height="42" Background="#FEE2E2" CornerRadius="12">
                            <TextBlock Text="E" Foreground="#B91C1C" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource DashboardCard}"
                        Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Recent Active Bookings" Style="{StaticResource PanelHeading}"/>
                                <TextBlock Text="Latest guests currently checked in"
                                           Margin="0,4,0,0"
                                           Foreground="#64748B"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Background="#ECFDF5"
                                    CornerRadius="12"
                                    Padding="12,7"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Live" Foreground="#047857" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <DataGrid x:Name="RecentBookingsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  MinHeight="300"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Customer" Binding="{Binding Customer}" Width="*"/>
                                <DataGridTextColumn Header="Room" Binding="{Binding Room}" Width="90"/>
                                <DataGridTextColumn Header="Check In" Binding="{Binding CheckIn}" Width="120"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="120"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Quick Overview" Style="{StaticResource PanelHeading}"/>

                            <Grid Margin="0,18,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Occupied Rooms" Foreground="#64748B" FontSize="14"/>
                                <TextBlock x:Name="OccupiedRoomsTextBlock" Grid.Column="1" FontWeight="Bold" Foreground="#0F172A" Text="0"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Occupancy Rate" Foreground="#64748B" FontSize="14"/>
                                <TextBlock x:Name="OccupancyRateTextBlock" Grid.Column="1" FontWeight="Bold" Foreground="#0F172A" Text="0%"/>
                            </Grid>

                            <Border Height="10"
                                    Background="#E2E8F0"
                                    CornerRadius="5"
                                    Margin="0,4,0,16">
                                <ProgressBar x:Name="OccupancyProgressBar"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="0"
                                             Foreground="#16A34A"
                                             Background="Transparent"
                                             BorderThickness="0"/>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Booking Revenue" Foreground="#64748B" FontSize="14"/>
                                <TextBlock x:Name="RevenueTextBlock" Grid.Column="1" FontWeight="Bold" Foreground="#0F172A" Text="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashboardCard}">
                        <StackPanel>
                            <TextBlock Text="Operations Notes" Style="{StaticResource PanelHeading}"/>

                            <Grid Margin="0,16,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" Fill="#16A34A" Margin="0,6,10,0"/>
                                <TextBlock Grid.Column="1" Text="Review active bookings regularly" Foreground="#64748B" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" Fill="#0EA5E9" Margin="0,6,10,0"/>
                                <TextBlock Grid.Column="1" Text="Keep room status updated" Foreground="#64748B" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" Fill="#F59E0B" Margin="0,6,10,0"/>
                                <TextBlock Grid.Column="1" Text="Use check-out to free occupied rooms" Foreground="#64748B" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

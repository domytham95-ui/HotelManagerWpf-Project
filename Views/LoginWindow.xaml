<Window x:Class="HotelManagerWpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotel Manager - Login"
        Height="620"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#EAFBF1">

    <Window.Resources>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Background" Value="#16A34A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#15803D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="35">
        <Border CornerRadius="28" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.18"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        CornerRadius="28,0,0,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#BBF7D0" Offset="0"/>
                            <GradientStop Color="#22C55E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <StackPanel VerticalAlignment="Center"
                                    Margin="48">
                            <TextBlock Text="HOTEL"
                                       FontSize="50"
                                       FontWeight="Bold"
                                       Foreground="#064E3B"/>

                            <TextBlock Text="MANAGEMENT"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       Foreground="#065F46"
                                       Margin="0,8,0,0"/>

                            <Rectangle Width="86"
                                       Height="4"
                                       Fill="#064E3B"
                                       HorizontalAlignment="Left"
                                       Margin="0,26,0,0"/>

                            <TextBlock Text="Hotel Management System"
                                       FontSize="17"
                                       Foreground="#14532D"
                                       Margin="0,26,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1"
                      Background="#F8FAFC">
                    <Border Background="White"
                            Width="430"
                            MinHeight="455"
                            CornerRadius="24"
                            Padding="42,36,42,36"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.12"/>
                        </Border.Effect>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Welcome Back"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#064E3B"
                                       Margin="0,0,0,8"
                                       TextOptions.TextFormattingMode="Display"/>

                            <TextBlock Text="Login to continue"
                                       FontSize="14"
                                       Foreground="#6B7280"
                                       Margin="0,0,0,30"/>

                            <TextBlock Text="Username"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"/>

                            <TextBox x:Name="UsernameTextBox"
                                     Style="{StaticResource InputTextBox}"
                                     Margin="0,8,0,18"/>

                            <TextBlock Text="Password"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"/>

                            <PasswordBox x:Name="PasswordBox"
                                         Style="{StaticResource InputPasswordBox}"
                                         Margin="0,8,0,26"/>

                            <Button Content="Login"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="LoginButton_Click"/>

                            <Button Content="Create new account"
                                    Style="{StaticResource LinkButton}"
                                    Margin="0,14,0,0"
                                    Click="OpenRegisterButton_Click"/>

                            <TextBlock Text="admin / 123456"
                                       HorizontalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       FontSize="13"
                                       Margin="0,18,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
<UserControl x:Class="HotelManagerWpf.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Employee Management"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="#065F46"
                   Margin="0,0,0,24"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="18"
                    Padding="22">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Employee Form"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#065F46"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Full Name"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="FullNameTextBox"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Gender"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <ComboBox x:Name="GenderComboBox"
                              Margin="0,6,0,12">
                        <ComboBoxItem Content="Male"/>
                        <ComboBoxItem Content="Female"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>

                    <TextBlock Text="Phone Number"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="PhoneTextBox"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Position"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="PositionTextBox"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Salary"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="SalaryTextBox"
                             Margin="0,6,0,12"/>

                    <TextBlock Text="Hire Date"
                               Foreground="#334155"
                               FontWeight="SemiBold"/>

                    <DatePicker x:Name="HireDatePicker"
                                Margin="0,6,0,18"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save"
                                Style="{StaticResource SuccessActionButton}"
                                Click="SaveButton_Click"/>

                        <Button Content="Clear"
                                Style="{StaticResource SecondaryActionButton}"
                                Click="ClearButton_Click"/>

                        <Button Content="Delete"
                                Style="{StaticResource DangerActionButton}"
                                Click="DeleteButton_Click"/>
                    </StackPanel>
                </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="18"
                    Padding="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.08"/>
                </Border.Effect>

                <DataGrid x:Name="EmployeesDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HorizontalScrollBarVisibility="Auto"
                          SelectionChanged="EmployeesDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="55"/>

                        <DataGridTextColumn Header="Full Name"
                                            Binding="{Binding FullName}"
                                            Width="160"/>

                        <DataGridTextColumn Header="Gender"
                                            Binding="{Binding Gender}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Phone"
                                            Binding="{Binding PhoneNumber}"
                                            Width="125"/>

                        <DataGridTextColumn Header="Position"
                                            Binding="{Binding Position}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Salary"
                                            Binding="{Binding Salary, StringFormat=N0}"
                                            Width="110"/>

                        <DataGridTextColumn Header="Hire Date"
                                            Binding="{Binding HireDate, StringFormat=dd/MM/yyyy}"
                                            Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

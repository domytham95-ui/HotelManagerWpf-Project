<Window x:Class="HotelManagerWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotel Manager"
        Height="720"
        Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="#F0FDF4">

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="18,0,18,12"/>
            <Setter Property="Background" Value="#0F766E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutButton" TargetType="Button" BasedOn="{StaticResource MenuButton}">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#064E3B"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="18,0,18,26"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#064E3B">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,36,24,34">
                    <TextBlock Text="Hotel"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="Manager"
                               Foreground="#BBF7D0"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0"/>

                    <Rectangle Width="60"
                               Height="4"
                               Fill="#22C55E"
                               HorizontalAlignment="Left"
                               Margin="0,18,0,0"/>

                    <TextBlock x:Name="CurrentUserTextBlock"
                               Foreground="#DCFCE7"
                               FontSize="13"
                               Margin="0,18,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button x:Name="DashboardButton"
                            Content="Dashboard"
                            Style="{StaticResource MenuButton}"
                            Click="DashboardButton_Click"/>

                    <Button x:Name="RoomsButton"
                            Content="Rooms"
                            Style="{StaticResource MenuButton}"
                            Click="RoomsButton_Click"/>

                    <Button x:Name="CustomerRegistrationButton"
                            Content="Customer Registration"
                            Style="{StaticResource MenuButton}"
                            Click="CustomerRegistrationButton_Click"/>

                    <Button x:Name="CustomerDetailsButton"
                            Content="Customer Details"
                            Style="{StaticResource MenuButton}"
                            Click="CustomerDetailsButton_Click"/>

                    <Button x:Name="CheckOutButton"
                            Content="Check Out"
                            Style="{StaticResource MenuButton}"
                            Click="CheckOutButton_Click"/>

                    <Button x:Name="EmployeesButton"
                            Content="Employees"
                            Style="{StaticResource MenuButton}"
                            Click="EmployeesButton_Click"/>

                    <Button x:Name="UserStatusButton"
                            Content="User Status"
                            Style="{StaticResource MenuButton}"
                            Click="UserStatusButton_Click"/>
                </StackPanel>

                <Button Grid.Row="2"
                        Content="Logout"
                        Style="{StaticResource LogoutButton}"
                        Click="LogoutButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="#F0FDF4">
            <Grid Margin="28">
                <Border Background="White"
                        CornerRadius="24"
                        Padding="22">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          ShadowDepth="0"
                                          Opacity="0.08"/>
                    </Border.Effect>

                    <ContentControl x:Name="MainContent"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
